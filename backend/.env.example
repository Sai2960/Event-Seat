# MONGODB_URI: Connection string for MongoDB (e.g. mongodb+srv://username:password@cluster0.abcde.mongodb.net/eventseat)
# If omitted or empty, the server automatically boots an in-memory Mongo database for instant local evaluation.
MONGODB_URI=

# JWT_SECRET: Secret key used to sign and verify JSON Web Tokens.
JWT_SECRET=super_secret_jwt_sign_key_9911

# PORT: The port that the backend server binds to (default is 3000 in unified run mode).
PORT=3000
